# Gleam
/build
*.beam
*.ez
erl_crash.dump

# Hive build output (generated by `hive build` next to each entrypoint)
*.hive-build/

# Compiled example binaries. On Linux/macOS they have no extension (the
# binary is named after the .hive entrypoint), so only whitelisted source and
# asset files are tracked inside code-examples/.
*.exe
code-examples/**
!code-examples/**/
!code-examples/**/*.hive
!code-examples/**/*.csv
